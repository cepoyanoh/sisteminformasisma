<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Sistem Informasi Manajemen Kurikulum - SMA Negeri 12 Pontianak' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }
        .header-bg {
            background: linear-gradient(135deg, #0d6efd, #0b5ed7);
            color: white;
        }
        .sidebar {
            background-color: #ffffff;
            border-right: 1px solid #dee2e6;
        }
        .footer {
            background-color: #f8f9fa;
            padding: 1rem 0;
            margin-top: 2rem;
            border-top: 1px solid #dee2e6;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header-bg py-3 mb-4">
        <div class="container-fluid">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <h3 class="text-white mb-0">SMA Negeri 12 Pontianak</h3>
                </div>
                <div class="text-end">
                    <span class="text-light">Sistem Informasi Manajemen Kurikulum</span>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <nav class="col-md-2 col-lg-2 sidebar d-none d-md-block bg-light">
                <div class="position-sticky pt-3">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="bi bi-house-door me-2"></i>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/kelas">
                                <i class="bi bi-journal me-2"></i>
                                Data Kelas
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/mapel">
                                <i class="bi bi-book me-2"></i>
                                Mata Pelajaran
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/guru">
                                <i class="bi bi-people me-2"></i>
                                Data Guru
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/jurnal">
                                <i class="bi bi-journal-bookmark me-2"></i>
                                Jurnal Guru
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="bi bi-calendar me-2"></i>
                                Jadwal Pelajaran
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="bi bi-file-text me-2"></i>
                                Laporan
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>

            <!-- Main Content -->
            <main class="col-md-10 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2"><%= typeof heading !== 'undefined' ? heading : (typeof title !== 'undefined' ? title.replace(' - SMA Negeri 12 Pontianak', '') : 'Dashboard') %></h1>
                </div>