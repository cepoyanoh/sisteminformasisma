<% layout('layout') -%>

<div class="dashboard-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bug me-2 text-danger"></i>Database Diagnostic - Alpha Status</h2>
        <div class="d-flex gap-2">
            <a href="/absensi" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-2"></i>Kembali ke Absensi
            </a>
            <% if (allAlphaRecords.length === 0) { %>
                <a href="/absensi/insert-test-alpha" class="btn btn-success" onclick="return confirm('Insert 5 test alpha records untuk siswa pertama?')">
                    <i class="bi bi-plus-circle me-2"></i>Insert Test Alpha
                </a>
            <% } %>
            <a href="/absensi/fix-alpha" class="btn btn-warning" onclick="return confirm('Fix all alpa to alpha?')">
                <i class="bi bi-wrench me-2"></i>Fix 'alpa' to 'alpha'
            </a>
        </div>
    </div>

    <!-- Flash Messages -->
    <% if (success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
    
    <% if (error && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <!-- Overview Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= totalCount %></h3>
                    <small>Total Records in Database</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= allAlphaRecords.length %></h3>
                    <small>Total Alpha (All Time)</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= todayAlphaRecords.length %></h3>
                    <small>Alpha Today (<%= today %>)</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert jika tidak ada data alpha -->
    <% if (allAlphaRecords.length === 0) { %>
        <div class="alert alert-danger">
            <h5><i class="bi bi-exclamation-triangle me-2"></i>TIDAK ADA DATA ALPHA DI DATABASE!</h5>
            <p class="mb-0">Ini berarti data alpha belum pernah tersimpan ke database.</p>
            <hr>
            <strong> Solusi Cepat:</strong>
            <ol class="mb-0">
                <li>Klik tombol <strong>"Insert Test Alpha"</strong> di atas (tombol hijau) untuk insert 5 data alpha test</li>
                <li>Setelah insert, refresh halaman ini untuk melihat hasilnya</li>
                <li>Atau coba input ulang absensi dengan status Alpha melalui form input biasa</li>
            </ol>
        </div>
    <% } %>
    
    <% if (todayAlphaRecords.length === 0 && allAlphaRecords.length > 0) { %>
        <div class="alert alert-warning">
            <h5><i class="bi bi-info-circle me-2"></i>Ada Data Alpha tapi Tidak untuk Hari Ini</h5>
            <p class="mb-0">Database memiliki <%= allAlphaRecords.length %> data alpha, tapi tidak ada untuk tanggal <strong><%= today %></strong>.</p>
            <p class="mb-0">Kemungkinan: Anda input alpha untuk tanggal yang berbeda.</p>
        </div>
    <% } %>

    <!-- Unique Status -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-list-check me-2"></i>Unique Status Values in Database</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <% uniqueStatus.forEach(s => { %>
                    <div class="col-md-3 mb-2">
                        <span class="badge bg-secondary fs-6">"<%= s.status_kehadiran %>"</span>
                        <% if (s.status_kehadiran === 'alpa') { %>
                            <span class="badge bg-danger ms-2">TYPO!</span>
                        <% } %>
                    </div>
                <% }); %>
            </div>
        </div>
    </div>

    <!-- Status Distribution -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Status Distribution (All Time)</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Count</th>
                        <th>Percentage</th>
                        <th>Badge</th>
                    </tr>
                </thead>
                <tbody>
                    <% statusDist.forEach(s => { %>
                        <tr>
                            <td><strong>"<%= s.status_kehadiran %>"</strong></td>
                            <td><%= s.count %></td>
                            <td><%= ((s.count / totalCount) * 100).toFixed(1) %>%</td>
                            <td>
                                <% if (s.status_kehadiran === 'hadir') { %>
                                    <span class="badge bg-success">Hadir</span>
                                <% } else if (s.status_kehadiran === 'sakit') { %>
                                    <span class="badge bg-warning">Sakit</span>
                                <% } else if (s.status_kehadiran === 'izin') { %>
                                    <span class="badge bg-info">Izin</span>
                                <% } else if (s.status_kehadiran === 'alpha') { %>
                                    <span class="badge bg-danger">Alpha</span>
                                <% } else if (s.status_kehadiran === 'alpa') { %>
                                    <span class="badge bg-danger">Alpha (Typo!)</span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><%= s.status_kehadiran %></span>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Today's Alpha Records -->
    <% if (todayAlphaRecords.length > 0) { %>
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-calendar-day me-2"></i>Alpha Records for TODAY (<%= today %>)</h5>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped">
                    <thead class="table-warning">
                        <tr>
                            <th>No</th>
                            <th>NIS</th>
                            <th>Nama Siswa</th>
                            <th>Kelas</th>
                            <th>Mapel</th>
                            <th>Guru</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% todayAlphaRecords.forEach((r, index) => { %>
                            <tr class="<%= r.status_kehadiran === 'alpa' ? 'table-warning' : 'table-danger' %>">
                                <td><%= index + 1 %></td>
                                <td><%= r.nis %></td>
                                <td><strong><%= r.nama_siswa %></strong></td>
                                <td><%= r.nama_kelas %></td>
                                <td><%= r.nama_mapel %></td>
                                <td><%= r.nama_guru %></td>
                                <td>
                                    <span class="badge <%= r.status_kehadiran === 'alpa' ? 'bg-warning' : 'bg-danger' %>">
                                        <%= r.status_kehadiran %>
                                        <% if (r.status_kehadiran === 'alpa') { %>
                                            <small>(Typo!)</small>
                                        <% } %>
                                    </span>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    <% } %>

    <!-- All Alpha Records -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>ALL Alpha Records in Database (<%= allAlphaRecords.length %> records)</h5>
        </div>
        <div class="card-body">
            <% if (allAlphaRecords.length > 0) { %>
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong>Good!</strong> Found <%= allAlphaRecords.length %> alpha record(s) in database.
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered table-striped">
                        <thead class="table-danger">
                            <tr>
                                <th>No</th>
                                <th>Tanggal</th>
                                <th>NIS</th>
                                <th>Nama Siswa</th>
                                <th>Kelas</th>
                                <th>Mapel</th>
                                <th>Guru</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% allAlphaRecords.forEach((r, index) => { %>
                                <tr class="<%= r.status_kehadiran === 'alpa' ? 'table-warning' : '' %>">
                                    <td><%= index + 1 %></td>
                                    <td><%= new Date(r.tanggal).toLocaleDateString('id-ID') %></td>
                                    <td><%= r.nis %></td>
                                    <td><strong><%= r.nama_siswa %></strong></td>
                                    <td><%= r.nama_kelas %></td>
                                    <td><%= r.nama_mapel %></td>
                                    <td><%= r.nama_guru %></td>
                                    <td>
                                        <span class="badge <%= r.status_kehadiran === 'alpa' ? 'bg-warning' : 'bg-danger' %>">
                                            <%= r.status_kehadiran %>
                                            <% if (r.status_kehadiran === 'alpa') { %>
                                                <small>(Typo!)</small>
                                            <% } %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle me-2"></i>
                    <strong>No alpha records found in entire database!</strong> 
                    <p class="mb-0">This means data alpha was never saved or there's an issue with the save process.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>