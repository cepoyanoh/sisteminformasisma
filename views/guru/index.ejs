<% layout('layout') -%>

<!-- Flash Messages -->
<% if (typeof success !== 'undefined' && success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i><%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof warning !== 'undefined' && warning.length > 0) { %>
  <div class="alert alert-warning alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= warning %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof error !== 'undefined' && error.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-x-circle-fill me-2"></i><%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<!-- Tampilkan error detail dari import jika ada -->
<% if (typeof importErrors !== 'undefined' && importErrors && importErrors.length > 0) { %>
  <div class="alert alert-warning" role="alert">
    <h6 class="alert-heading"><i class="bi bi-exclamation-triangle me-2"></i>Detail Error Import:</h6>
    <ul class="mb-0">
      <% importErrors.forEach(err => { %>
        <li><%= err %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<div class="d-flex justify-content-between flex-wrap align-items-center mb-3">
    <h3>Data Guru</h3>
    <div>
        <a href="/guru/import" class="btn btn-success me-2">
            <i class="bi bi-file-earmark-excel"></i> Import Excel
        </a>
        <a href="/guru/tambah" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Tambah Guru Baru
        </a>
    </div>
</div>

<% if (guruList && guruList.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nomor</th>
                    <th>NIP</th>
                    <th>Nama Guru</th>
                    <th>Jenis Kelamin</th>
                    <th>Alamat</th>
                    <th>Nomor Telepon</th>
                    <th>Email</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% guruList.forEach((guru, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= guru.nip %></td>
                        <td><%= guru.nama_guru %></td>
                        <td><%= guru.jenis_kelamin %></td>
                        <td><%= guru.alamat || '-' %></td>
                        <td><%= guru.nomor_telepon || '-' %></td>
                        <td><%= guru.email || '-' %></td>
                        <td>
                            <a href="/guru/edit/<%= guru.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a href="/guru/hapus/<%= guru.id %>" class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('Yakin ingin menghapus guru <%= guru.nama_guru %>?')">
                                <i class="bi bi-trash"></i> Hapus
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Belum ada data guru. <a href="/guru/tambah" class="alert-link">Tambah guru baru</a>
    </div>
<% } %>

<!-- Auto scroll to top when flash message exists -->
<% if ((typeof success !== 'undefined' && success.length > 0) || 
        (typeof error !== 'undefined' && error.length > 0) || 
        (typeof warning !== 'undefined' && warning.length > 0)) { %>
    <script>
        window.addEventListener('DOMContentLoaded', function() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    </script>
<% } %>
