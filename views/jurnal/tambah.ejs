<% layout('layout') -%>

<h3>Tambah Jurnal Guru Baru</h3>

<form method="POST" action="/jurnal/tambah">
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label for="guru_id" class="form-label">Nama Guru</label>
                <select class="form-select" id="guru_id" name="guru_id" required>
                    <option value="">Pilih Guru</option>
                    <% guruList.forEach(guru => { %>
                        <option value="<%= guru.id %>"><%= guru.nama_guru %> (<%= guru.nip %>)</option>
                    <% }) %>
                </select>
            </div>
            
            <div class="mb-3">
                <label for="tanggal" class="form-label">Tanggal</label>
                <input type="date" class="form-control" id="tanggal" name="tanggal" required>
            </div>
            
            <div class="mb-3">
                <label for="jam_ke" class="form-label">Jam Ke-</label>
                <input type="number" class="form-control" id="jam_ke" name="jam_ke" min="1" max="10" required>
            </div>
            
            <div class="mb-3">
                <label for="kelas_id" class="form-label">Kelas</label>
                <select class="form-select" id="kelas_id" name="kelas_id" required onchange="updateJumlahSiswa()">
                    <option value="">Pilih Kelas</option>
                    <% kelasList.forEach(kelas => { %>
                        <option value="<%= kelas.id %>" data-jumlah-siswa="<%= kelas.jumlah_siswa || 0 %>"><%= kelas.nama_kelas %> (<%= kelas.jumlah_siswa || 0 %> siswa)</option>
                    <% }) %>
                </select>
            </div>
            
            <div class="mb-3">
                <label for="mapel_id" class="form-label">Mata Pelajaran</label>
                <select class="form-select" id="mapel_id" name="mapel_id" required>
                    <option value="">Pilih Mata Pelajaran</option>
                    <% mapelList.forEach(mapel => { %>
                        <option value="<%= mapel.id %>"><%= mapel.nama_mapel %></option>
                    <% }) %>
                </select>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="mb-3">
                <label for="materi" class="form-label">Materi Pokok</label>
                <textarea class="form-control" id="materi" name="materi" rows="3" placeholder="Tulis materi pokok yang diajarkan" required></textarea>
            </div>
            
            <div class="mb-3">
                <label for="metode_pembelajaran" class="form-label">Metode Pembelajaran</label>
                <input type="text" class="form-control" id="metode_pembelajaran" name="metode_pembelajaran" placeholder="Contoh: Ceramah, Diskusi, Praktik">
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="jumlah_siswa_hidden" class="form-label">Jumlah Siswa (diambil dari data kelas)</label>
                        <input type="number" class="form-control" id="jumlah_siswa_display" name="jumlah_siswa_display" min="0" readonly>
                        <input type="hidden" id="jumlah_siswa" name="jumlah_siswa" value="0">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="hadir" class="form-label">Jumlah Hadir</label>
                        <input type="number" class="form-control" id="hadir" name="hadir" min="0">
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="sakit" class="form-label">Sakit</label>
                        <input type="number" class="form-control" id="sakit" name="sakit" min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="izin" class="form-label">Izin</label>
                        <input type="number" class="form-control" id="izin" name="izin" min="0">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="alpha" class="form-label">Alpha</label>
                        <input type="number" class="form-control" id="alpha" name="alpha" min="0">
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="catatan" class="form-label">Catatan</label>
                <textarea class="form-control" id="catatan" name="catatan" rows="2" placeholder="Catatan tambahan jika ada"></textarea>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Simpan Jurnal</button>
                <a href="/jurnal" class="btn btn-secondary">Batal</a>
            </div>
        </div>
    </div>
</form>

<script>
    function updateJumlahSiswa() {
        const kelasSelect = document.getElementById('kelas_id');
        const jumlahSiswaDisplay = document.getElementById('jumlah_siswa_display');
        const jumlahSiswaHidden = document.getElementById('jumlah_siswa');
        
        if (kelasSelect.value) {
            const selectedOption = kelasSelect.options[kelasSelect.selectedIndex];
            const jumlahSiswa = selectedOption.getAttribute('data-jumlah-siswa');
            jumlahSiswaDisplay.value = jumlahSiswa;
            jumlahSiswaHidden.value = jumlahSiswa;
        } else {
            jumlahSiswaDisplay.value = '';
            jumlahSiswaHidden.value = '0';
        }
    }

    // Initialize the jumlah siswa field if a kelas is already selected
    document.addEventListener('DOMContentLoaded', function() {
        updateJumlahSiswa();
    });
</script>