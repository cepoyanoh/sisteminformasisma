<% layout('layout') -%>

<div class="d-flex justify-content-between flex-wrap align-items-center mb-3">
    <h3>Data Kelas</h3>
    <a href="/kelas/tambah" class="btn btn-primary">Tambah Kelas Baru</a>
</div>

<% if (kelasList && kelasList.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nomor</th>
                    <th>Nama Kelas</th>
                    <th>Wali Kelas</th>
                    <th>Tahun Pelajaran</th>
                    <th>Jumlah Siswa</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% kelasList.forEach((kelas, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><%= kelas.nama_kelas %></td>
                        <td><%= kelas.wali_kelas_nama || '-' %></td>
                        <td><%= kelas.tahun_pelajaran %></td>
                        <td><%= kelas.jumlah_siswa || 0 %> siswa</td>
                        <td>
                            <a href="/kelas/edit/<%= kelas.id %>" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a href="/kelas/hapus/<%= kelas.id %>" class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('Yakin ingin menghapus kelas <%= kelas.nama_kelas %>?')">Hapus</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info">
        Belum ada data kelas. <a href="/kelas/tambah">Tambah kelas baru</a>
    </div>
<% } %>