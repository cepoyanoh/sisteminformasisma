<% layout('layout') -%>

<div class="dashboard-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-bug me-2 text-danger"></i>Diagnostic Tool - Cek Data Alpha</h2>
        <a href="/absensi" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Kembali ke Absensi
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card <%= results.alphaCount > 0 ? 'bg-success' : 'bg-warning' %> text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= results.alphaCount %></h3>
                    <small>Total Record Alpha</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= results.totalAbsensi %></h3>
                    <small>Total Semua Absensi</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card <%= results.typoCount > 0 ? 'bg-danger' : 'bg-success' %> text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= results.typoCount %></h3>
                    <small>Typo "alpa"</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h3 class="mb-0"><%= results.today %></h3>
                    <small>Tanggal Hari Ini</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Distribution -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Distribusi Status Keseluruhan</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Jumlah</th>
                            <th>Persentase</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% 
                        const totalAll = results.statusDistribution.reduce((sum, item) => sum + item.count, 0);
                        const statusIcons = {
                            'hadir': '✅',
                            'sakit': '🤒',
                            'izin': '📧',
                            'alpha': '❌',
                            'alpa': '❌ (typo)'
                        };
                        %>
                        <% results.statusDistribution.forEach(item => { %>
                            <tr>
                                <td>
                                    <span class="badge <%= item.status_kehadiran === 'alpha' || item.status_kehadiran === 'alpa' ? 'bg-danger' : item.status_kehadiran === 'hadir' ? 'bg-success' : item.status_kehadiran === 'sakit' ? 'bg-warning' : 'bg-info' %>">
                                        <%= statusIcons[item.status_kehadiran] || '❓' %> <%= item.status_kehadiran.charAt(0).toUpperCase() + item.status_kehadiran.slice(1) %>
                                    </span>
                                </td>
                                <td><strong><%= item.count %></strong></td>
                                <td>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar <%= item.status_kehadiran === 'alpha' || item.status_kehadiran === 'alpa' ? 'bg-danger' : item.status_kehadiran === 'hadir' ? 'bg-success' : item.status_kehadiran === 'sakit' ? 'bg-warning' : 'bg-info' %>" 
                                             role="progressbar" 
                                             style="width: <%= (item.count / totalAll * 100).toFixed(1) %>%"
                                             aria-valuenow="<%= item.count %>" 
                                             aria-valuemin="0" 
                                             aria-valuemax="<%= totalAll %>">
                                            <%= (item.count / totalAll * 100).toFixed(1) %>%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Today's Breakdown -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-calendar-day me-2"></i>Absensi Hari Ini (<%= results.today %>)</h5>
        </div>
        <div class="card-body">
            <% if (results.todayBreakdown.length === 0) { %>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i>Belum ada data absensi untuk hari ini
                </div>
            <% } else { %>
                <div class="row">
                    <% 
                    const todayTotal = results.todayBreakdown.reduce((sum, item) => sum + item.count, 0);
                    results.todayBreakdown.forEach(item => { 
                        const icons = {
                            'hadir': 'bi-check-circle-fill text-success',
                            'sakit': 'bi-thermometer-half text-warning',
                            'izin': 'bi-envelope-fill text-info',
                            'alpha': 'bi-x-circle-fill text-danger',
                            'alpa': 'bi-x-circle-fill text-danger'
                        };
                    %>
                        <div class="col-md-3 mb-3">
                            <div class="card border-<%= item.status_kehadiran === 'alpha' || item.status_kehadiran === 'alpa' ? 'danger' : item.status_kehadiran === 'hadir' ? 'success' : item.status_kehadiran === 'sakit' ? 'warning' : 'info' %>">
                                <div class="card-body text-center">
                                    <i class="bi <%= icons[item.status_kehadiran] || 'bi-question-circle' %>" style="font-size: 2rem;"></i>
                                    <h4 class="mt-2 mb-0"><%= item.count %></h4>
                                    <small class="text-muted"><%= item.status_kehadiran.charAt(0).toUpperCase() + item.status_kehadiran.slice(1) %></small>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Recent Alpha Records -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>10 Record Alpha Terbaru</h5>
        </div>
        <div class="card-body">
            <% if (results.recentAlpha.length === 0) { %>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>Tidak ada record Alpha di database
                    
                    <% if (results.alphaCount === 0 && results.totalAbsensi === 0) { %>
                        <hr>
                        <p class="mb-0"><strong>Saran:</strong></p>
                        <ul class="mb-0">
                            <li>Mulai dengan input absensi di menu <a href="/absensi/input">Input Absensi</a></li>
                            <li>Pastikan memilih tombol "Alpha" (merah) untuk siswa yang tidak hadir</li>
                            <li>Klik "Simpan Absensi" dan tunggu konfirmasi sukses</li>
                        </ul>
                    <% } %>
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead class="table-light">
                            <tr>
                                <th>No</th>
                                <th>Nama Siswa</th>
                                <th>Kelas</th>
                                <th>Mapel</th>
                                <th>Guru</th>
                                <th>Tanggal</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% results.recentAlpha.forEach((record, index) => { %>
                                <% const typo = record.status_kehadiran === 'alpa' ? ' ⚠️ TYPO!' : ''; %>
                                <tr class="<%= record.status_kehadiran === 'alpha' || record.status_kehadiran === 'alpa' ? 'table-danger' : '' %>">
                                    <td><%= index + 1 %></td>
                                    <td><strong><%= record.nama_siswa || '-' %></strong></td>
                                    <td><%= record.nama_kelas || '-' %></td>
                                    <td><%= record.nama_mapel || '-' %></td>
                                    <td><%= record.nama_guru || '-' %></td>
                                    <td><%= new Date(record.tanggal).toLocaleDateString('id-ID') %></td>
                                    <td>
                                        <span class="badge bg-danger">
                                            <%= record.status_kehadiran === 'alpa' ? 'Alpha (typo)' : 'Alpha' %>
                                        </span>
                                        <%= typo %>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Actions -->
    <div class="mt-4 d-flex gap-2">
        <a href="/absensi/check-alpha/insert-test" class="btn btn-warning">
            <i class="bi bi-plus-circle me-2"></i>Insert Test Alpha
        </a>
        <button onclick="location.reload()" class="btn btn-primary">
            <i class="bi bi-arrow-clockwise me-2"></i>Refresh Data
        </button>
    </div>
</div>

<!-- Auto scroll to top -->
<script>
    window.addEventListener('DOMContentLoaded', function() {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
</script>
