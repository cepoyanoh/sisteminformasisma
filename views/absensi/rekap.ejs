<% layout('layout') -%>

<div class="dashboard-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar3 me-2 text-primary"></i><%= heading %></h2>
        <div class="d-flex gap-2">
            <% if (rekapData && rekapData.length > 0) { %>
                <a href="/absensi/rekap/export?kelas_id=<%= selectedKelas %>&bulan=<%= selectedBulan %>&tahun=<%= selectedTahun %>" 
                   class="btn btn-success">
                    <i class="bi bi-file-earmark-spreadsheet me-2"></i>Export Excel
                </a>
            <% } %>
            <a href="/" class="btn btn-outline-secondary">
                <i class="bi bi-house-door me-2"></i>Dashboard
            </a>
            <a href="/absensi" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-2"></i>Kembali
            </a>
        </div>
    </div>

    <!-- Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="GET" action="/absensi/rekap" class="row g-3">
                <div class="col-md-3">
                    <label for="bulan" class="form-label">Bulan</label>
                    <select class="form-select" id="bulan" name="bulan">
                        <% for (let i = 1; i <= 12; i++) { %>
                            <option value="<%= i %>" <%= selectedBulan == i ? 'selected' : '' %>>
                                <%= new Date(2000, i-1, 1).toLocaleDateString('id-ID', { month: 'long' }) %>
                            </option>
                        <% } %>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="tahun" class="form-label">Tahun</label>
                    <input type="number" class="form-control" id="tahun" name="tahun" 
                           value="<%= selectedTahun %>" min="2000" max="2100">
                </div>
                <div class="col-md-4">
                    <label for="kelas_id" class="form-label">Kelas</label>
                    <select class="form-select" id="kelas_id" name="kelas_id">
                        <option value="">-- Pilih Kelas --</option>
                        <% if (kelasList && kelasList.length > 0) { %>
                            <% kelasList.forEach(kelas => { %>
                                <option value="<%= kelas.id %>" <%= selectedKelas == kelas.id ? 'selected' : '' %>>
                                    <%= kelas.nama_kelas %>
                                </option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-2"></i>Tampilkan
                    </button>
                </div>
            </form>
        </div>
    </div>

    <% if (selectedKelas && selectedBulan && selectedTahun) { %>
        <!-- Summary Cards -->
        <% if (summary) { %>
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-title mb-1">Rata-rata Hadir</h6>
                                    <h2 class="mb-0"><%= summary.rataRataHadir %>%</h2>
                                </div>
                                <i class="bi bi-graph-up" style="font-size: 2.5rem; opacity: 0.3;"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-title mb-1">Total Siswa</h6>
                                    <h2 class="mb-0"><%= summary.totalSiswa %></h2>
                                </div>
                                <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.3;"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-dark">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-title mb-1">Siswa Terbaik</h6>
                                    <h5 class="mb-0"><%= summary.siswaTerbaik ? summary.siswaTerbaik.nama_siswa : '-' %></h5>
                                    <% if (summary.siswaTerbaik) { %>
                                        <small><%= summary.siswaTerbaik.persentaseHadir %>% kehadiran</small>
                                    <% } %>
                                </div>
                                <i class="bi bi-trophy" style="font-size: 2.5rem; opacity: 0.3;"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-danger text-white">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="card-title mb-1">Perlu Perhatian</h6>
                                    <h5 class="mb-0"><%= summary.siswaTerendah ? summary.siswaTerendah.nama_siswa : '-' %></h5>
                                    <% if (summary.siswaTerendah) { %>
                                        <small><%= summary.siswaTerendah.persentaseHadir %>% kehadiran</small>
                                    <% } %>
                                </div>
                                <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem; opacity: 0.3;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detailed Statistics -->
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h6 class="card-title mb-3">Statistik Detail</h6>
                            <div class="row">
                                <div class="col-md-3 text-center">
                                    <div class="p-3 bg-success bg-opacity-10 rounded">
                                        <h4 class="text-success mb-1"><%= summary.totalHadir %></h4>
                                        <small class="text-muted">Total Hadir</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="p-3 bg-warning bg-opacity-10 rounded">
                                        <h4 class="text-warning mb-1"><%= summary.totalSakit %></h4>
                                        <small class="text-muted">Total Sakit</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="p-3 bg-info bg-opacity-10 rounded">
                                        <h4 class="text-info mb-1"><%= summary.totalIzin %></h4>
                                        <small class="text-muted">Total Izin</small>
                                    </div>
                                </div>
                                <div class="col-md-3 text-center">
                                    <div class="p-3 bg-danger bg-opacity-10 rounded">
                                        <h4 class="text-danger mb-1"><%= summary.totalAlpha %></h4>
                                        <small class="text-muted">Total Tidak Hadir</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } %>

        <!-- Tabel Rekap -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="mb-3">
                    Rekap Absensi: <%= new Date(selectedTahun, selectedBulan-1, 1).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' }) %>
                    <% if (kelas) { %>
                        <span class="badge bg-primary ms-2"><%= kelas.nama_kelas %></span>
                    <% } %>
                </h5>
                
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">Ranking</th>
                                <th>No</th>
                                <th>NIS</th>
                                <th>Nama Siswa</th>
                                <th class="text-center bg-success text-white">Hadir</th>
                                <th class="text-center bg-warning text-dark">Sakit</th>
                                <th class="text-center bg-info text-white">Izin</th>
                                <th class="text-center bg-danger text-white">Alpha</th>
                                <th class="text-center">Total</th>
                                <th class="text-center">% Hadir</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (rekapData && rekapData.length > 0) { %>
                                <% rekapData.forEach((rekap, index) => { %>
                                    <tr>
                                        <td class="text-center">
                                            <% if (rekap.ranking === 1) { %>
                                                <span class="badge bg-warning text-dark">🏆 <%= rekap.ranking %></span>
                                            <% } else if (rekap.ranking === 2) { %>
                                                <span class="badge bg-secondary">🥈 <%= rekap.ranking %></span>
                                            <% } else if (rekap.ranking === 3) { %>
                                                <span class="badge bg-danger">🥉 <%= rekap.ranking %></span>
                                            <% } else { %>
                                                <span class="badge bg-light text-dark"><%= rekap.ranking %></span>
                                            <% } %>
                                        </td>
                                        <td><%= index + 1 %></td>
                                        <td><%= rekap.nis || '-' %></td>
                                        <td><strong><%= rekap.nama_siswa || '-' %></strong></td>
                                        <td class="text-center"><span class="badge bg-success"><%= rekap.hadir %></span></td>
                                        <td class="text-center"><span class="badge bg-warning text-dark"><%= rekap.sakit || 0 %></span></td>
                                        <td class="text-center"><span class="badge bg-info"><%= rekap.izin || 0 %></span></td>
                                        <td class="text-center"><span class="badge bg-danger"><%= rekap.alpha || 0 %></span></td>
                                        <td class="text-center"><strong><%= rekap.total %></strong></td>
                                        <td class="text-center">
                                            <span class="badge <%= rekap.persentaseHadir >= 75 ? 'bg-success' : rekap.persentaseHadir >= 50 ? 'bg-warning' : 'bg-danger' %>">
                                                <%= rekap.persentaseHadir %>%
                                            </span>
                                        </td>
                                    </tr>
                                <% }); %>
                                
                                <!-- Summary Row -->
                                <tr class="table-primary">
                                    <td colspan="4" class="text-end"><strong>TOTAL:</strong></td>
                                    <td class="text-center">
                                        <strong><%= rekapData.reduce((sum, r) => sum + (r.hadir || 0), 0) %></strong>
                                    </td>
                                    <td class="text-center">
                                        <strong><%= rekapData.reduce((sum, r) => sum + (r.sakit || 0), 0) %></strong>
                                    </td>
                                    <td class="text-center">
                                        <strong><%= rekapData.reduce((sum, r) => sum + (r.izin || 0), 0) %></strong>
                                    </td>
                                    <td class="text-center">
                                        <strong><%= rekapData.reduce((sum, r) => sum + (r.alpha || 0), 0) %></strong>
                                    </td>
                                    <td class="text-center">
                                        <strong><%= rekapData.reduce((sum, r) => sum + (r.total || 0), 0) %></strong>
                                    </td>
                                    <td class="text-center">
                                        <% 
                                        const totalHari = rekapData.reduce((sum, r) => sum + (r.total || 0), 0);
                                        const totalHadir = rekapData.reduce((sum, r) => sum + (r.hadir || 0), 0);
                                        const totalPersentase = totalHari > 0 ? ((totalHadir / totalHari) * 100).toFixed(1) : 0;
                                        %>
                                        <strong><%= totalPersentase %>%</strong>
                                    </td>
                                </tr>
                            <% } else { %>
                                <tr>
                                    <td colspan="10" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox" style="font-size: 3rem; display: block; margin-bottom: 1rem;"></i>
                                        Belum ada data absensi untuk periode yang dipilih
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <i class="bi bi-calendar-check" style="font-size: 4rem; display: block; margin-bottom: 1rem;"></i>
                <h5>Silakan pilih kelas, bulan, dan tahun untuk melihat rekap bulanan</h5>
            </div>
        </div>
    <% } %>
</div>
