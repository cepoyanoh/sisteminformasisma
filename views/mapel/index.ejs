<% layout('layout') -%>

<!-- Flash Messages -->
<% if (typeof success !== 'undefined' && success.length > 0) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (typeof error !== 'undefined' && error.length > 0) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<div class="d-flex justify-content-between flex-wrap align-items-center mb-3">
    <h3>Data Mata Pelajaran</h3>
    <a href="/mapel/tambah" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Tambah Mata Pelajaran Baru
    </a>
</div>

<% if (mapelList && mapelList.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>No</th>
                    <th>Kode</th>
                    <th>Nama Mata Pelajaran</th>
                    <th>Kategori</th>
                    <th>Jam Pembelajaran</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% mapelList.forEach((mapel, index) => { %>
                    <tr>
                        <td><%= index + 1 %></td>
                        <td><span class="badge bg-secondary"><%= mapel.kode_mapel %></span></td>
                        <td><strong><%= mapel.nama_mapel %></strong></td>
                        <td>
                            <% if (mapel.kategori === 'Wajib') { %>
                                <span class="badge bg-primary">Wajib</span>
                            <% } else if (mapel.kategori === 'Pilihan') { %>
                                <span class="badge bg-success">Pilihan</span>
                            <% } else { %>
                                <span class="badge bg-warning text-dark">Muatan Lokal</span>
                            <% } %>
                        </td>
                        <td><%= mapel.jam_pembelajaran %> JP</td>
                        <td>
                            <a href="/mapel/edit/<%= mapel.id %>" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a href="/mapel/hapus/<%= mapel.id %>" class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('Yakin ingin menghapus mata pelajaran <%= mapel.nama_mapel %>?')">
                                <i class="bi bi-trash"></i> Hapus
                            </a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> Belum ada data mata pelajaran. <a href="/mapel/tambah" class="alert-link">Tambah mata pelajaran baru</a>
    </div>
<% } %>

<!-- Auto scroll to top when flash message exists -->
<% if ((typeof success !== 'undefined' && success.length > 0) || 
        (typeof error !== 'undefined' && error.length > 0)) { %>
    <script>
        window.addEventListener('DOMContentLoaded', function() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });
    </script>
<% } %>
