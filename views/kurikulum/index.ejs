<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link href="/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- block('content') -%>
    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<% layout('../layouts/layout') -%>

<div class="d-flex justify-content-between flex-wrap align-items-center mb-3">
    <h3>Data Kurikulum</h3>
    <a href="/tambah" class="btn btn-primary">Tambah Kurikulum Baru</a>
</div>

<% if (kurikulumList && kurikulumList.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nama Kurikulum</th>
                    <th>Tahun Pelajaran</th>
                    <th>Tingkat Pendidikan</th>
                    <th>Tanggal Berlaku</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% kurikulumList.forEach(kurikulum => { %>
                    <tr>
                        <td><%= kurikulum.id %></td>
                        <td><%= kurikulum.nama_kurikulum %></td>
                        <td><%= kurikulum.tahun_pelajaran %></td>
                        <td><%= kurikulum.tingkat_pendidikan %></td>
                        <td><%= kurikulum.tanggal_berlaku %></td>
                        <td>
                            <span class="badge <%= kurikulum.status === 'aktif' ? 'bg-success' : 'bg-secondary' %>">
                                <%= kurikulum.status %>
                            </span>
                        </td>
                        <td>
                            <a href="/edit/<%= kurikulum.id %>" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a href="/hapus/<%= kurikulum.id %>" class="btn btn-sm btn-outline-danger" 
                               onclick="return confirm('Yakin ingin menghapus kurikulum <%= kurikulum.nama_kurikulum %>?')">Hapus</a>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="alert alert-info">
        Belum ada data kurikulum. <a href="/tambah">Tambah kurikulum baru</a>
    </div>
<% } %>

<%- include('../partials/footer') -%>